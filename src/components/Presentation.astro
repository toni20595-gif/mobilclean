---
---

<section class="presentation-section" id="a-propos">
  <div class="container presentation-grid">
    <!-- Image gauche - asymétrique -->
    <div class="pres-visual reveal">
      <div class="pres-img-main">
        <img
          src="/images/galerie/alsace-3.jpg"
          alt="Zone d'intervention Mobil Clean - Alsace"
          width="480"
          height="560"
        />
      </div>
      <div class="pres-img-secondary reveal reveal-delay-2">
        <img
          src="/images/galerie/eco-responsable-1.png"
          alt="Produits éco-responsables Mobil Clean"
          width="240"
          height="240"
        />
        <div class="pres-badge-mobile">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          <div>
            <strong>Service certifié</strong>
            <span>Produits eco-responsables</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Texte droite -->
    <div class="pres-text reveal reveal-delay-1">
      <span class="tag">Qui sommes-nous</span>
      <h2>Votre spécialiste nettoyage <span class="accent-h2">en Alsace</span></h2>
      <p>
        <span class="hl">Mobil Clean</span>, spécialiste du nettoyage de <span class="hl">canapés, matelas, tapis et intérieurs de véhicules</span> <span class="hl">dans toute l'Alsace</span>. Nous intervenons directement à domicile avec un service professionnel, un séchage rapide et des résultats impeccables.
      </p>
      <p>
        Basée en Alsace, notre équipe se déplace dans <span class="hl">toute la région ainsi que les zones avoisinantes — le Haut-Rhin —</span> afin de vous proposer des prestations adaptées à vos besoins et à vos tissus.
      </p>
      <p>
        Grâce à notre savoir-faire et à notre <span class="hl">matériel professionnel</span>, nous redonnons fraîcheur, propreté et éclat à vos textiles d'ameublement et habitacles de voiture. Parce que votre confort et votre santé sont importants, nous utilisons des <span class="hl">produits respectueux, sans allergènes et sans composés nocifs</span> — <span class="hl">biodégradables et respectueux de l'environnement</span>.
      </p>

      <ul class="pres-points">
        <li>
          <div class="point-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
            </svg>
          </div>
          <div>
            <strong>Intervention rapide</strong>
            <span>Sous 48h en moyenne, 7j/7</span>
          </div>
        </li>
        <li>
          <div class="point-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <div>
            <strong>Produits professionnels</strong>
            <span>Eco-responsables et certifiés</span>
          </div>
        </li>
        <li>
          <div class="point-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <div>
            <strong>Résultat garanti</strong>
            <span>Ou on revient sans supplement</span>
          </div>
        </li>
        <li>
          <div class="point-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div>
            <strong>Zone d'intervention</strong>
            <span>Alsace et environs - Déplacement gratuit Mulhouse</span>
          </div>
        </li>
      </ul>

      <a href="/contact" class="btn-primary">Réserver une intervention</a>
    </div>
  </div>
</section>

<style>
  .presentation-section {
    padding-block: var(--section-gap);
    background: var(--blanc);
  }

  .presentation-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  /* Images asymétriques */
  .pres-visual {
    position: relative;
    height: 560px;
  }

  .pres-img-main {
    border-radius: var(--r-xl);
    overflow: hidden;
    height: 480px;
    box-shadow: 0 24px 64px var(--ombre);
  }
  .pres-img-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pres-img-secondary {
    position: absolute;
    bottom: 0;
    right: -32px;
    background: var(--blanc);
    border-radius: var(--r-lg);
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(0,0,0,0.15);
    border: 3px solid var(--teal-pale);
  }
  .pres-img-secondary img {
    width: 200px;
    height: 150px;
    object-fit: cover;
  }

  .pres-badge-mobile {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    background: var(--blanc);
    color: var(--bleu);
  }
  .pres-badge-mobile svg { color: var(--teal); flex-shrink: 0; }
  .pres-badge-mobile strong { display: block; font-size: 0.85rem; font-weight: 700; color: var(--bleu); }
  .pres-badge-mobile span { font-size: 0.75rem; color: var(--texte-2); }

  /* Texte */
  .pres-text {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .pres-text h2 { color: var(--bleu); }
  .accent-h2 {
    background: linear-gradient(90deg, var(--teal), var(--teal-clair));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .pres-text p { color: var(--texte-2); line-height: 1.75; }
  .hl { color: var(--bleu); font-weight: 600; }

  .pres-points {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .pres-points li {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .point-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--teal-pale);
    color: var(--teal);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .pres-points li strong { display: block; font-size: 0.95rem; color: var(--texte); font-weight: 600; }
  .pres-points li span { font-size: 0.85rem; color: var(--texte-2); }

  @media (max-width: 900px) {
    .presentation-grid { grid-template-columns: 1fr; gap: 40px; }
    .pres-visual { display: none; }
  }
</style>
