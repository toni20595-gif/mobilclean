---
import WarpHero from "./react/WarpHero.tsx";
---

<section class="hero">
  <!-- Shader WebGL background -->
  <WarpHero client:only="react" />

  <!-- Overlay dégradé pour lisibilité -->
  <div class="hero-overlay"></div>

  <!-- Contenu asymétrique (DESIGN_VARIANCE: 7) -->
  <div class="container hero-content">
    <div class="hero-left">
      <span class="hero-tag">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
        </svg>
        Service mobile - On se déplace chez vous
      </span>

      <h1>
        Propreté impeccable,<br />
        <span class="accent">à domicile.</span>
      </h1>

      <p class="hero-sub">
        Nettoyage professionnel de voitures, matelas et canapés. Nous intervenons directement chez vous avec un equipement haut de gamme.
      </p>

      <div class="hero-actions">
        <a href="/contact" class="btn-teal">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          Devis gratuit
        </a>
        <a href="/services" class="btn-outline">Voir les prestations</a>
      </div>

      <div class="hero-badges">
        <div class="badge">
          <strong>Alsace</strong>
          <span>Zone d'intervention</span>
        </div>
        <div class="badge-sep"></div>
        <div class="badge">
          <strong>Éco</strong>
          <span>Produits certifiés bio</span>
        </div>
        <div class="badge-sep"></div>
        <div class="badge">
          <strong>48h</strong>
          <span>délai moyen</span>
        </div>
      </div>
    </div>

    <div class="hero-right">
      <div class="hero-card">
        <img
          src="/images/galerie/mousseuse.jpg"
          alt="Nettoyage professionnel à la mousse"
          class="hero-card-img"
        />
        <div class="hero-card-badge">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2a10 10 0 100 20 10 10 0 000-20zm4.95 7.05L10.6 15.4a1 1 0 01-1.414 0l-2.83-2.83a1 1 0 111.414-1.414l2.122 2.12 5.644-5.644a1 1 0 011.414 1.414z"/>
          </svg>
          Résultat garanti
        </div>
      </div>
    </div>
  </div>

  <!-- Indicateur de scroll -->
  <div class="scroll-hint" aria-hidden="true">
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(13, 48, 128, 0.82) 0%,
      rgba(13, 48, 128, 0.55) 50%,
      rgba(0, 200, 150, 0.25) 100%
    );
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    padding-top: 100px;
    padding-bottom: 80px;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: rgba(0, 200, 150, 0.2);
    color: var(--teal-clair);
    border: 1px solid rgba(0, 200, 150, 0.35);
    border-radius: var(--r-full);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    width: fit-content;
  }

  h1 {
    color: var(--blanc);
    font-size: clamp(2.6rem, 5.5vw, 4.8rem);
  }

  .accent {
    background: linear-gradient(90deg, var(--teal), var(--teal-clair));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    color: rgba(255, 255, 255, 0.82);
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    line-height: 1.7;
    max-width: 480px;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .hero-badges {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    padding-top: 8px;
  }

  .badge {
    display: flex;
    flex-direction: column;
  }
  .badge strong {
    font-family: var(--font-titre);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--teal-clair);
    line-height: 1;
  }
  .badge span {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.65);
    margin-top: 2px;
  }

  .badge-sep {
    width: 1px;
    height: 36px;
    background: rgba(255,255,255,0.2);
  }

  /* Hero right - image card */
  .hero-right {
    display: flex;
    justify-content: flex-end;
  }

  .hero-card {
    position: relative;
    border-radius: var(--r-xl);
    overflow: hidden;
    box-shadow: 0 32px 80px rgba(0,0,0,0.4);
    border: 2px solid rgba(0, 200, 150, 0.3);
    max-width: 540px;
    width: 100%;
    animation: float 6s ease-in-out infinite;
  }

  .hero-card-img {
    width: 100%;
    height: 400px;
    object-fit: cover;
    display: block;
  }

  .hero-card-badge {
    position: absolute;
    bottom: 20px;
    left: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: rgba(0, 200, 150, 0.95);
    color: var(--bleu);
    font-weight: 700;
    font-size: 0.85rem;
    border-radius: var(--r-full);
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-12px); }
  }

  .scroll-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }
  .scroll-line {
    width: 2px;
    height: 50px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.6), transparent);
    margin-inline: auto;
    animation: scrollDown 2s ease-in-out infinite;
  }
  @keyframes scrollDown {
    0% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
    51% { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  @media (max-width: 900px) {
    .hero-content {
      grid-template-columns: 1fr;
      padding-top: 120px;
      text-align: center;
    }
    .hero-left { align-items: center; }
    .hero-sub { text-align: center; }
    .hero-right { display: none; }
    .hero-badges { justify-content: center; }
  }

  @media (max-width: 600px) {
    h1 {
      font-size: clamp(1.85rem, 8.5vw, 2.6rem);
    }
    .hero-tag {
      font-size: 0.72rem;
      padding: 7px 12px;
      max-width: calc(100vw - 48px);
      white-space: normal;
      line-height: 1.4;
      text-align: left;
    }
    .hero-content {
      padding-top: 110px;
    }
  }
</style>

