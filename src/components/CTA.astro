---
---

<section class="cta-section">
  <div class="container">
    <div class="cta-inner reveal">
      <div class="cta-deco" aria-hidden="true">
        <svg width="320" height="320" viewBox="0 0 320 320" fill="none">
          <circle cx="160" cy="160" r="160" fill="url(#g1)" opacity="0.15"/>
          <defs>
            <radialGradient id="g1" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#00C896"/>
              <stop offset="100%" stop-color="#0D3080"/>
            </radialGradient>
          </defs>
        </svg>
      </div>

      <div class="cta-content">
        <span class="tag cta-tag">Prise de contact gratuite</span>
        <h2>Prêt pour un intérieur impeccable ?</h2>
        <p>
          Obtenez un devis personnalisé en moins de 2 minutes. Intervention sous 48h, 7j/7 dans toute la region lyonnaise.
        </p>
        <div class="cta-actions">
          <a href="/contact" class="btn-teal">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
            Demander un devis
          </a>
          <a href="tel:+33600000000" class="btn-outline cta-tel">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Appeler directement
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding-block: var(--section-gap);
    background: var(--bleu);
  }

  .cta-inner {
    position: relative;
    background: linear-gradient(135deg, rgba(26, 86, 204, 0.5), rgba(0, 200, 150, 0.15));
    border: 1px solid rgba(0, 200, 150, 0.2);
    border-radius: var(--r-xl);
    padding: clamp(48px, 8vw, 80px);
    overflow: hidden;
  }

  .cta-deco {
    position: absolute;
    right: -80px;
    top: -80px;
    pointer-events: none;
  }

  .cta-content {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 640px;
  }

  .cta-tag {
    background: rgba(0, 200, 150, 0.15);
    color: var(--teal-clair);
    border: 1px solid rgba(0, 200, 150, 0.25);
  }

  .cta-content h2 { color: var(--blanc); font-size: clamp(1.8rem, 4vw, 3rem); }
  .cta-content p { color: rgba(255,255,255,0.75); font-size: 1.05rem; line-height: 1.7; }

  .cta-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  .cta-tel {
    background: transparent;
    border: 2px solid rgba(255,255,255,0.3);
    color: var(--blanc);
  }
  .cta-tel:hover {
    border-color: rgba(255,255,255,0.7);
    background: rgba(255,255,255,0.08);
  }
</style>
