---
// ════════════════════════════════════════════════════════════════════════
//  WIDGET D'AVIS GOOGLE — Mobil Clean   (auto-actualisé, gratuit, via Featurable)
//  ──────────────────────────────────────────────────────────────────────
//  Le widget Featurable affiche automatiquement les avis de la fiche Google
//  Business et SE MET À JOUR TOUT SEUL (~1×/jour). Aucun redéploiement, aucun
//  avis saisi à la main : tout vient en direct de Google.
//
//  POUR L'ACTIVER — une seule étape côté code :
//    1. Créer un compte gratuit sur https://featurable.com
//    2. Connecter la fiche Google Business « Mobil Clean »
//    3. Créer un widget → copier son identifiant
//       (il se trouve dans le code d'intégration, juste après "featurable-",
//        ex.  <div id="featurable-Wd8c0xk2..."  →  l'ID est  "Wd8c0xk2...")
//    4. Coller cet identifiant ci-dessous, entre les guillemets. C'est tout.
//
//  ⤵  Tant que cette valeur est VIDE, le site affiche une invitation à laisser
//     le premier avis (rien n'est inventé). Dès qu'elle est remplie, le vrai
//     widget Google s'affiche à la place, automatiquement.
// ════════════════════════════════════════════════════════════════════════
const FEATURABLE_WIDGET_ID = "8df78142-04ac-4c20-a746-83a4a5f7b3fe"; // widget « MobilClean » (Featurable)

// Lien direct vers la fiche Google (bouton « laisser un avis »).
// Lien de partage officiel fourni par l'utilisateur → mène à la fiche MobilClean.
const GOOGLE_AVIS_URL = "https://share.google/ApsMCWECCMibAbFYM";
---

<section class="avis-section" id="avis">
  <div class="container">
    <div class="section-head reveal">
      <span class="tag">Avis clients</span>
      <h2>Votre satisfaction, notre priorité</h2>
      <p class="section-sub">
        Tous nos avis sont publiés sur notre fiche Google, sans filtre. Vous avez
        fait appel à nous ? Votre retour aide les prochains clients à nous faire
        confiance.
      </p>
    </div>

    {FEATURABLE_WIDGET_ID ? (
      <!-- ══ Widget Google live, alimenté et actualisé automatiquement ══ -->
      <div class="avis-widget reveal">
        <div id={`featurable-${FEATURABLE_WIDGET_ID}`} data-featurable-async></div>
      </div>
    ) : (
    <!-- ══ Repli : fiche neuve → invitation à laisser le premier avis ══ -->
    <div class="avis-invite reveal">
      <!-- Logo Google -->
      <svg
        class="invite-google"
        width="92"
        height="30"
        viewBox="0 0 92 30"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-label="Google"
      >
        <text x="0" y="23" font-family="Arial,sans-serif" font-size="26" font-weight="bold">
          <tspan fill="#4285F4">G</tspan><tspan fill="#EA4335">o</tspan><tspan
            fill="#FBBC05">o</tspan><tspan fill="#4285F4">g</tspan><tspan
            fill="#34A853">l</tspan><tspan fill="#EA4335">e</tspan>
        </text>
      </svg>

      <!-- 5 étoiles "à remplir" (contour) : invite à noter -->
      <div class="invite-stars" aria-hidden="true">
        {Array.from({ length: 5 }).map(() => (
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#FBBC05" stroke-width="1.5">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 21 12 17.77 5.82 21 7 14.14 2 9.27l6.91-1.01L12 2z" />
          </svg>
        ))}
      </div>

      <h3>Soyez le premier à laisser un avis</h3>
      <p>
        Notre fiche Google vient d'ouvrir. Si notre intervention vous a plu, un
        petit avis nous aiderait énormément — ça prend moins d'une minute.
      </p>

      <a
        href={GOOGLE_AVIS_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="invite-cta"
      >
        <!-- "G" Google multicolore -->
        <svg width="20" height="20" viewBox="0 0 48 48" aria-hidden="true">
          <path fill="#4285F4" d="M44.5 20H24v8.5h11.8C34.7 33.9 30.1 37 24 37c-7.2 0-13-5.8-13-13s5.8-13 13-13c3.1 0 5.9 1.1 8.1 2.9l6.4-6.4C34.6 4.1 29.6 2 24 2 11.8 2 2 11.8 2 24s9.8 22 22 22c11 0 21-8 21-22 0-1.3-.2-2.7-.5-4z"/>
          <path fill="#34A853" d="M6.3 14.7l7 5.1C15.1 16.1 19.2 13 24 13c3.1 0 5.9 1.1 8.1 2.9l6.4-6.4C34.6 4.1 29.6 2 24 2 15.4 2 8 6.9 6.3 14.7z" opacity="0"/>
        </svg>
        Laisser un avis sur Google
      </a>
    </div>
    )}

    <!-- CTA toujours visible : laisser un avis (le widget masque le bloc invitation) -->
    <div class="avis-review-cta-wrap reveal">
      <a href={GOOGLE_AVIS_URL} target="_blank" rel="noopener noreferrer" class="invite-cta">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#fff" aria-hidden="true">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
        </svg>
        Laisser un avis sur Google
      </a>
    </div>

    <!-- Bloc de confiance -->
    <div class="avis-trust reveal">
      <div class="trust-item">
        <div class="trust-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
          </svg>
        </div>
        <div>
          <strong>Avis 100 % Google</strong>
          <span>Publiés directement sur notre fiche</span>
        </div>
      </div>
      <div class="trust-sep"></div>
      <div class="trust-item">
        <div class="trust-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" />
            <path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" />
          </svg>
        </div>
        <div>
          <strong>De vrais clients</strong>
          <span>Interventions réelles en Alsace</span>
        </div>
      </div>
      <div class="trust-sep"></div>
      <div class="trust-item">
        <div class="trust-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
          </svg>
        </div>
        <div>
          <strong>Satisfaction garantie</strong>
          <span>Ou on revient sans frais</span>
        </div>
      </div>
    </div>
  </div>
</section>

{/* Script Featurable : chargé seulement quand le widget est activé. */}
{FEATURABLE_WIDGET_ID && (
  <script is:inline defer charset="UTF-8" src="https://featurable.com/assets/bundle.js"></script>
)}

<style>
  .avis-section {
    padding-block: var(--section-gap);
    background: var(--fond);
  }

  .section-head {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 48px;
  }
  .section-head h2 { color: var(--bleu); }
  .section-sub { color: var(--texte-2); max-width: 520px; }

  /* Conteneur du widget Google live (Featurable) */
  .avis-widget {
    margin-bottom: 40px;
  }
  .avis-widget :global([id^="featurable-"]) {
    min-height: 120px; /* évite le saut de mise en page pendant le chargement */
  }

  /* Carte d'invitation à laisser un avis */
  .avis-invite {
    background: var(--blanc);
    border-radius: var(--r-xl);
    padding: 48px 32px;
    box-shadow: 0 4px 24px var(--ombre);
    margin-bottom: 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
  }

  .invite-google { display: block; }

  .invite-stars {
    display: flex;
    gap: 4px;
  }

  .avis-invite h3 {
    font-family: var(--font-titre);
    font-size: clamp(1.25rem, 3vw, 1.6rem);
    color: var(--bleu);
    margin: 0;
  }

  .avis-invite p {
    color: var(--texte-2);
    max-width: 440px;
    line-height: 1.65;
    margin: 0;
  }

  .invite-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 8px;
    padding: 14px 28px;
    border-radius: var(--r-full);
    background: #4285F4;
    color: #fff;
    font-size: 0.95rem;
    font-weight: 600;
    box-shadow: 0 4px 14px rgba(66, 133, 244, 0.35);
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
  }
  .invite-cta:hover {
    background: #3367d6;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(66, 133, 244, 0.45);
  }
  .invite-cta svg path { fill: #fff; }

  .avis-review-cta-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 40px;
  }

  /* Bloc de confiance */
  .avis-trust {
    display: flex;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
    justify-content: center;
    background: var(--blanc);
    border-radius: var(--r-xl);
    padding: 28px 40px;
    box-shadow: 0 4px 24px var(--ombre);
  }
  .trust-item { display: flex; align-items: center; gap: 14px; }
  .trust-icon {
    width: 48px; height: 48px; border-radius: 12px;
    background: var(--teal-pale); color: var(--teal);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .trust-item strong { display: block; font-size: 0.95rem; color: var(--texte); font-weight: 600; }
  .trust-item span { font-size: 0.82rem; color: var(--texte-2); }
  .trust-sep { width: 1px; height: 48px; background: rgba(13, 48, 128, 0.1); flex-shrink: 0; }

  @media (max-width: 768px) {
    .avis-invite { padding: 36px 22px; }
    .avis-trust { flex-direction: column; align-items: flex-start; padding: 24px; }
    .trust-sep { width: 100%; height: 1px; }
  }
</style>
