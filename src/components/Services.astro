---
import { services } from "../data/services";
---

<section class="services-section" id="services">
  <div class="container">
    <div class="section-head reveal">
      <span class="tag">Nos prestations</span>
      <h2>Un service pour chaque besoin</h2>
      <p>Equipement professionnel, produits haut de gamme, résultat garanti.</p>
    </div>

    <!-- Grille uniforme 3 colonnes pour tous les services -->
    <div class="bento-trio">
      {services.map((service, i) => (
        <div class={`bento-card bento-small reveal reveal-delay-${i % 3}`}>
          <div class="bento-img-wrap">
            <img src={service.image} alt={service.alt} loading="lazy" />
            <div class="bento-overlay"></div>
          </div>
          <div class="bento-content">
            <span class="bento-tag">{service.tarif || "Sur devis"}</span>
            <h3>{service.titre}</h3>
            <p class="bento-desc-short">{service.description}</p>
            <a href={`/services#${service.id}`} class="bento-link">
              Découvrir
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    padding-block: var(--section-gap);
    background: var(--fond);
  }

  .section-head {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 56px;
    max-width: 560px;
  }
  .section-head h2 { color: var(--bleu); }
  .section-head p { color: var(--texte-2); }

  .bento-card {
    position: relative;
    border-radius: var(--r-xl);
    overflow: hidden;
    background: var(--blanc);
    box-shadow: 0 4px 24px var(--ombre);
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.35s;
  }
  .bento-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(13, 48, 128, 0.18);
  }

  .bento-img-wrap {
    position: relative;
    overflow: hidden;
  }
  .bento-img-wrap { height: 200px; }

  .bento-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .bento-card:hover .bento-img-wrap img {
    transform: scale(1.05);
  }

  .bento-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(13,48,128,0.3));
  }

  .bento-content {
    padding: 24px 28px 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .bento-tag {
    display: inline-flex;
    padding: 4px 12px;
    background: var(--teal-pale);
    color: var(--teal);
    font-size: 0.78rem;
    font-weight: 700;
    border-radius: var(--r-full);
    letter-spacing: 0.04em;
    width: fit-content;
  }

  .bento-content h3 {
    font-size: 1.15rem;
    color: var(--bleu);
    margin-bottom: 4px;
  }

  .bento-content p { color: var(--texte-2); font-size: 0.95rem; line-height: 1.6; }
  .bento-desc-short {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bento-details {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 4px;
  }
  .bento-details li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.88rem;
    color: var(--texte-2);
  }
  .bento-details li svg { color: var(--teal); flex-shrink: 0; }

  .bento-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 6px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--bleu-royal);
    transition: gap 0.2s, color 0.2s;
  }
  .bento-link:hover { gap: 10px; color: var(--teal); }

  .bento-trio {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 20px;
  }

  @media (max-width: 600px) {
    .bento-trio { grid-template-columns: 1fr; }
  }

  @media (min-width: 601px) and (max-width: 900px) {
    .bento-trio { grid-template-columns: repeat(2, 1fr); }
  }
</style>
