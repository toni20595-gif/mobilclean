---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WarpHero from "../components/react/WarpHero.tsx";
import CreneauxPicker from "../components/CreneauxPicker.astro";
---

<Layout
  title="Réserver un créneau - Mobil Clean"
  description="Réservez en ligne le nettoyage de votre voiture, matelas ou canapé : choisissez vos créneaux, on vous confirme sous 24h. Devis gratuit, sans engagement."
>
  <Header />
  <main>
    <section class="page-hero">
      <WarpHero client:only="react" />
      <div class="page-hero-overlay"></div>
      <div class="container page-hero-content">
        <span class="tag">Réservation en ligne</span>
        <h1>Réservez votre créneau</h1>
        <p>Choisissez votre prestation et les créneaux qui vous arrangent — on vous confirme le bon très vite. Devis gratuit, sans engagement.</p>
      </div>
    </section>

    <section class="contact-section">
      <div class="container contact-grid">
        <!-- Formulaire -->
        <div class="form-wrap reveal">
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            class="contact-form"
            id="contact-form"
            novalidate
          >
            <input type="hidden" name="form-name" value="contact" />

            <div class="form-row">
              <div class="form-group">
                <label for="nom">Nom complet <span aria-hidden="true">*</span></label>
                <input type="text" id="nom" name="nom" required placeholder="Jean Dupont" autocomplete="name" />
              </div>
              <div class="form-group">
                <label for="tel">Téléphone <span aria-hidden="true">*</span></label>
                <input type="tel" id="tel" name="telephone" required placeholder="06 00 00 00 00" autocomplete="tel" />
              </div>
            </div>

            <div class="form-group">
              <label for="email">Email <span aria-hidden="true">*</span></label>
              <input type="email" id="email" name="email" required placeholder="jean@exemple.fr" autocomplete="email" />
            </div>

            <div class="form-group">
              <label for="prestation">Type de prestation <span aria-hidden="true">*</span></label>
              <select id="prestation" name="prestation" required>
                <option value="" disabled selected>Choisissez une prestation</option>
                <option value="voiture">Nettoyage voiture</option>
                <option value="matelas">Nettoyage matelas</option>
                <option value="canape">Nettoyage canapé</option>
                <option value="tapis">Nettoyage tapis</option>
                <option value="fauteuil">Nettoyage fauteuil</option>
                <option value="formule-multi">Formule multi-meubles</option>
                <option value="multiple">Plusieurs prestations</option>
              </select>
            </div>

            <div class="form-group" id="formule-group" hidden>
              <label>Formule souhaitée <span aria-hidden="true">*</span></label>
              <div class="formule-radio-group">
                <label class="frc frc-or">
                  <input type="radio" name="formule" value="or" />
                  <span class="frc-star" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  </span>
                  <span class="frc-name">Or</span>
                  <span class="frc-prix">89€</span>
                </label>
                <label class="frc frc-diamant">
                  <input type="radio" name="formule" value="diamant" />
                  <span class="frc-popular-tag">🔥 Le plus choisi</span>
                  <span class="frc-star" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6.5 2h11l4.5 6-10 14L2 8z"/><polyline points="2 8 12 8 17.5 2" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
                  </span>
                  <span class="frc-name">Diamant</span>
                  <span class="frc-badge-small">Tout inclus</span>
                  <span class="frc-prix">129€</span>
                </label>
              </div>
              <p id="formule-preselect" class="formule-preselect" hidden></p>
              <p class="form-note" style="margin-top:6px">Le tarif définitif dépend de la taille de votre véhicule — on vous le confirme rapidement.</p>
            </div>

            <CreneauxPicker />

            <div class="form-group">
              <label for="message">Message / détails</label>
              <textarea id="message" name="message" rows="5" placeholder="Décrivez votre besoin : type de véhicule, taille du canapé, état actuel..."></textarea>
            </div>

            <button type="submit" class="btn-primary form-submit">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="m9 16 2 2 4-4"/>
              </svg>
              <span id="submit-label">Envoyer ma demande</span>
            </button>

            <p class="form-note">On vous répond sous 24h (souvent bien plus vite). Vos données ne sont jamais revendues.</p>
          </form>
        </div>

        <!-- Infos contact -->
        <aside class="contact-aside reveal reveal-delay-2">
          <div class="contact-card">
            <h3>Informations de contact</h3>
            <ul class="contact-list">
              <li>
                <div class="contact-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.79 19.79 0 0 1 11.19 19 19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                  </svg>
                </div>
                <div>
                  <strong>Téléphone</strong>
                  <a href="tel:+33644830555">06 44 83 05 55</a>
                </div>
              </li>
              <li>
                <div class="contact-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
                  </svg>
                </div>
                <div>
                  <strong>Email</strong>
                  <a href="mailto:Mobilclean68@gmail.com">Mobilclean68@gmail.com</a>
                </div>
              </li>
              <li>
                <div class="contact-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                  </svg>
                </div>
                <div>
                  <strong>Disponibilité</strong>
                  <span>7j/7 de 10h à 21h</span>
                </div>
              </li>
              <li>
                <div class="contact-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                  </svg>
                </div>
                <div>
                  <strong>Zone d'intervention</strong>
                  <span>Alsace et environs - Gratuit Mulhouse et périphérie</span>
                </div>
              </li>
            </ul>
          </div>

          <div class="guarantees">
            <h4>Nos garanties</h4>
            <ul>
              <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Devis gratuit et sans engagement</li>
              <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Résultat garanti ou retour gratuit</li>
              <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Produits eco-responsables</li>
              <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Paiement après intervention</li>
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <!-- Carte de la zone d'intervention -->
    <section class="map-section">
      <div class="container">
        <div class="map-head reveal">
          <span class="tag">Zone d'intervention</span>
          <h2>On se déplace dans toute l'Alsace</h2>
          <p>Basés à Mulhouse, nous intervenons à domicile dans le Haut-Rhin et ses environs. Déplacement gratuit sur Mulhouse et sa périphérie.</p>
        </div>
        <div class="map-frame reveal reveal-delay-1">
          <iframe
            src="https://www.google.com/maps?q=Mulhouse,France&z=11&output=embed"
            title="Zone d'intervention Mobil Clean — Mulhouse et Haut-Rhin"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    padding: 160px 0 80px;
  }
  .page-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(13,48,128,0.85) 0%, rgba(13,48,128,0.6) 60%, rgba(0,200,150,0.2) 100%);
    z-index: 1;
  }
  .page-hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .page-hero .tag { background: rgba(0,200,150,0.2); color: var(--teal-clair); border: 1px solid rgba(0,200,150,0.3); }
  .page-hero h1 { color: var(--blanc); }
  .page-hero p { color: rgba(255,255,255,0.75); max-width: 480px; }

  .contact-section { padding-block: var(--section-gap); background: var(--fond); }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .form-wrap, .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-group label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--texte);
  }
  .form-group label span { color: var(--teal); }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 14px 16px;
    border: 2px solid rgba(13,48,128,0.12);
    border-radius: var(--r-md);
    font-family: var(--font-corps);
    font-size: 0.95rem;
    color: var(--texte);
    background: var(--blanc);
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    width: 100%;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--bleu);
    box-shadow: 0 0 0 4px rgba(13, 48, 128, 0.08);
  }
  .form-group input.error,
  .form-group select.error,
  .form-group textarea.error {
    border-color: #e53e3e;
  }
  .form-group textarea { resize: vertical; min-height: 120px; }

  /* Formule radio cards */
  .formule-radio-group {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .frc {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    padding: 14px 8px;
    border: 2px solid rgba(13,48,128,0.12);
    border-radius: var(--r-md);
    cursor: pointer;
    text-align: center;
    transition: border-color 0.2s, background 0.2s, transform 0.12s;
  }
  .frc:hover { transform: translateY(-1px); }
  .frc input[type="radio"] { position: absolute; opacity: 0; width: 0; height: 0; }

  .frc-star { display: flex; align-items: center; }
  .frc-or      .frc-star { color: #C9920E; }
  .frc-diamant .frc-star { color: #2563EB; }

  .frc-name {
    font-family: var(--font-titre);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--texte);
  }
  .frc-prix { font-size: 0.75rem; color: var(--texte-2); line-height: 1.3; }

  .frc-badge-small {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: #2563EB;
    color: #fff;
    padding: 1px 7px;
    border-radius: 20px;
    line-height: 1.8;
  }

  .frc-or.active      { border-color: #C9920E; background: rgba(201,146,14,0.08); }
  .frc-diamant { border-color: rgba(239,68,68,0.28) !important; }
  .frc-diamant.active { border-color: #EF4444 !important; background: rgba(239,68,68,0.06); }

  .frc-popular-tag {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #EF4444;
    margin-bottom: 2px;
  }
  .frc-or.active      .frc-name { color: #C9920E; }
  .frc-diamant.active .frc-name { color: #2563EB; }

  .formule-preselect {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 9px 14px;
    background: var(--teal-pale);
    color: var(--teal);
    border-radius: var(--r-sm);
    font-size: 0.8rem;
    font-weight: 600;
    margin-top: 6px;
  }

  .error-group .formule-radio-group {
    outline: 2px solid #e53e3e;
    border-radius: var(--r-md);
  }
  .error-group > label { color: #e53e3e; }

  .form-submit { width: 100%; justify-content: center; font-size: 1rem; }

  .form-note {
    font-size: 0.78rem;
    color: var(--texte-2);
    text-align: center;
  }

  /* Aside */
  .contact-aside { display: flex; flex-direction: column; gap: 20px; }

  .contact-card {
    background: var(--blanc);
    border-radius: var(--r-xl);
    padding: 32px;
    box-shadow: 0 4px 24px var(--ombre);
  }
  .contact-card h3 { color: var(--bleu); margin-bottom: 24px; font-size: 1.2rem; }

  .contact-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .contact-list li { display: flex; align-items: flex-start; gap: 14px; }

  .contact-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--teal-pale);
    color: var(--teal);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-list strong { display: block; font-size: 0.85rem; font-weight: 700; color: var(--texte); margin-bottom: 2px; }
  .contact-list a, .contact-list span { font-size: 0.9rem; color: var(--texte-2); }
  .contact-list a:hover { color: var(--teal); }

  .guarantees {
    background: var(--bleu);
    border-radius: var(--r-xl);
    padding: 28px 32px;
  }
  .guarantees h4 { color: var(--teal-clair); margin-bottom: 16px; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em; }
  .guarantees ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .guarantees li { display: flex; align-items: center; gap: 10px; font-size: 0.9rem; color: rgba(255,255,255,0.85); }
  .guarantees li svg { color: var(--teal); flex-shrink: 0; }

  /* Carte zone d'intervention */
  .map-section { padding-bottom: var(--section-gap); background: var(--fond); }
  .map-head {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 32px;
    max-width: 560px;
  }
  .map-head h2 { color: var(--bleu); }
  .map-head p { color: var(--texte-2); }
  .map-frame {
    border-radius: var(--r-xl);
    overflow: hidden;
    box-shadow: 0 4px 24px var(--ombre);
    border: 1px solid rgba(13, 48, 128, 0.08);
    line-height: 0;
  }
  .map-frame iframe { width: 100%; height: 420px; border: 0; filter: grayscale(0.15); }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .map-frame iframe { height: 320px; }
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const prestationSelect = document.getElementById("prestation") as HTMLSelectElement;
  const formuleGroup = document.getElementById("formule-group") as HTMLDivElement;
  const formulePreselect = document.getElementById("formule-preselect") as HTMLParagraphElement;

  const FORMULE_LABELS: Record<string, string> = {
    or: "Or",
    diamant: "Diamant",
  };

  function showFormuleGroup(visible: boolean) {
    if (!formuleGroup) return;
    formuleGroup.hidden = !visible;
    if (!visible) {
      document.querySelectorAll<HTMLInputElement>('input[name="formule"]').forEach(r => { r.checked = false; });
      document.querySelectorAll(".frc").forEach(c => c.classList.remove("active"));
    }
  }

  if (prestationSelect) {
    prestationSelect.addEventListener("change", () => {
      showFormuleGroup(prestationSelect.value === "voiture");
    });
  }

  // Radio card visual selection
  document.querySelectorAll(".frc").forEach(card => {
    card.addEventListener("click", () => {
      document.querySelectorAll(".frc").forEach(c => c.classList.remove("active"));
      card.classList.add("active");
      formuleGroup?.classList.remove("error-group");
    });
  });

  // Pre-populate from URL params (?prestation=voiture&formule=argent)
  const params = new URLSearchParams(window.location.search);
  const prestationParam = params.get("prestation");
  const formuleParam = params.get("formule");

  if (prestationSelect && prestationParam === "voiture") {
    prestationSelect.value = "voiture";
    showFormuleGroup(true);

    if (formuleParam && FORMULE_LABELS[formuleParam]) {
      const radio = document.querySelector<HTMLInputElement>(`input[name="formule"][value="${formuleParam}"]`);
      const card = document.querySelector<HTMLElement>(`.frc-${formuleParam}`);
      if (radio && card) {
        radio.checked = true;
        card.classList.add("active");
      }
      if (formulePreselect) {
        formulePreselect.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Formule ${FORMULE_LABELS[formuleParam]} pré-sélectionnée — vous pouvez modifier si besoin.`;
        formulePreselect.hidden = false;
      }
    }
  }

  // Form validation
  if (form) {
    form.addEventListener("submit", (e) => {
      let valid = true;

      form.querySelectorAll("[required]").forEach((field) => {
        const el = field as HTMLInputElement | HTMLSelectElement;
        if (!el.value.trim()) {
          el.classList.add("error");
          valid = false;
        } else {
          el.classList.remove("error");
        }
      });

      // Valider la formule si voiture est sélectionné
      if (prestationSelect?.value === "voiture" && formuleGroup && !formuleGroup.hidden) {
        const checked = form.querySelector<HTMLInputElement>('input[name="formule"]:checked');
        if (!checked) {
          formuleGroup.classList.add("error-group");
          valid = false;
        } else {
          formuleGroup.classList.remove("error-group");
        }
      }

      // NB : les créneaux sont FACULTATIFS — une simple demande de devis
      // doit pouvoir partir sans en choisir aucun. Aucune validation ici.

      if (!valid) {
        e.preventDefault();
        (form.querySelector(".error") ?? form.querySelector(".error-group"))?.scrollIntoView({ behavior: "smooth", block: "center" });
      }
    });

    form.querySelectorAll("input, select, textarea").forEach((el) => {
      el.addEventListener("input", () => el.classList.remove("error"));
    });
  }
</script>
